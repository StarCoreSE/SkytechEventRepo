			<Description>SkyTech Engine Turbochargers</Description>
			<Blocks>
				<Block Type="MyObjectBuilder_CubeBlock" Subtype="ST_T_InlineTurboLeft" />
				<Block Type="MyObjectBuilder_CubeBlock" Subtype="ST_T_InlineTurboRight" />
				<Block Type="MyObjectBuilder_CubeBlock" Subtype="ST_T_TurbochargerLeft" />
				<Block Type="MyObjectBuilder_CubeBlock" Subtype="ST_T_TurbochargerRight" />
			</Blocks>
		</BlockVariantGroup>
		

	</BlockVariantGroups>
</Definitions>